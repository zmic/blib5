   "source": [
    "from contextlib import contextmanager\n",
    "\n",
    "@contextmanager\n",
    "def connect():\n",
    "    # Setup (optional)\n",
    "    def f(x):\n",
    "        print(x)\n",
    "    try:\n",
    "        yield f    \n",
    "    finally:\n",
    "        # Cleanup always runs\n",
    "        print(\"Exiting context\")\n",
    "\n",
    "with connect() as sendf:\n",
    "    sendf(1)\n",
    "    sendf(2)\n",
    "    "
   ]
